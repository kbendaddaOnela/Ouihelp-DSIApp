# =============================================================================
# apps/web — Variables Vite (préfixe VITE_ obligatoire pour être exposées côté client)
# Copier en .env.local
# =============================================================================

VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/${VITE_AZURE_TENANT_ID}

# Scope de l'API interne DSI App (à créer dans Azure Portal > App Registrations > Expose an API)
VITE_API_SCOPE=api://${VITE_AZURE_CLIENT_ID}/access_as_user

VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api
