# =============================================================================
# DSI App — Variables d'environnement
# Copier ce fichier en .env.local (jamais commité)
# =============================================================================

# --- Microsoft Entra ID (SSO) ---
# Récupérer dans Azure Portal > App Registrations > DSI App
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_AUTHORITY=https://login.microsoftonline.com/${AZURE_TENANT_ID}

# --- Microsoft Graph ---
GRAPH_SCOPE=https://graph.microsoft.com/.default

# --- Google Workspace (Phase 2) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_WORKSPACE_DOMAIN=

# --- Slack (Phase 3) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL_CORE_IT=
SLACK_WEBHOOK_URL_SUPPORT_APP=

# --- Supabase / PostgreSQL (Phase 2) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- App ---
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
